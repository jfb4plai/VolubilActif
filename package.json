{
  "name": "volubilactif",
  "productName": "VolubilActif",
  "version": "1.5.0",
  "description": "Dictee vocale 100% locale pour eleves DYS (FWB), adaptation PLAI de Volubil-IA",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "icons": "node tools/make-icon.js",
    "check": "node tools/check.js"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Jean-Francois Beguin (PLAI), d'apres Volubil-IA d'Anne-Cecile Le Dain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jfb4plai/VolubilActif.git"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "be.plai.volubilactif",
    "productName": "VolubilActif",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "jfb4plai",
      "repo": "VolubilActif"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "preload.js",
      "icon.png"
    ],
    "asarUnpack": [
      "node_modules/uiohook-napi/**"
    ],
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "vendor/win",
          "to": "bin"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "artifactName": "VolubilActif-Windows-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "VolubilActif-Mac-${version}.${ext}",
      "extraResources": [
        {
          "from": "vendor/mac",
          "to": "bin"
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "VolubilActif utilise le micro pour la dictee vocale, entierement en local."
      }
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "uiohook-napi@1.5.5": true
  }
}
